# Copy to deploy/arena.env (gitignored) and fill in. Loaded by:
#   docker compose --env-file deploy/arena.env -f docker-compose.arena.yml up -d

# Postgres password for the arena DB (any strong value; only used internally).
ARENA_DB_PASSWORD=change-me

# Shared secret that gates the admin/import endpoint. MUST equal the value set
# on the newblades-web container (ARENA_IMPORT_TOKEN) so /arena Transfer works.
ARENA_IMPORT_TOKEN=change-me-too

# DEBUG/experimental: Bearer token gating the arena packet-injection routes
# (/arena/debug/peers + /arena/debug/inject) used to fire hand-crafted s2c frames
# into a live connected peer. If UNSET, those routes fall back to
# ARENA_IMPORT_TOKEN; with neither set the routes are disabled (503). Leave unset
# to reuse ARENA_IMPORT_TOKEN, or set a distinct value here to scope the debug
# surface separately. See server/src/arena/debug_inject.rs.
# ARENA_DEBUG_TOKEN=

# DEBUG/experimental FREEZE for inspecting the round-start. When set to 1, a
# connected match sends the FULL round-start burst then HOLDS at
# BackendMatchCreated forever: it never advances to the live combat round, no bot
# swings, and a solo (under-capacity) peer is NOT swept/timed-out — so a lone emu
# that taps FIGHT stays connected indefinitely. Drive the held match by hand with
# the /arena/debug/peers + /arena/debug/inject routes (op79 MatchStateChangeRequest
# etc.) to find what advances the client past "connecting". Empty/unset = normal
# matches (byte-identical to before this flag existed). Recreate the arena-server
# container to apply (no rebuild needed). See server/src/arena/combat/engine.rs.
# ARENA_DEBUG_HOLD=1

# Host:port advertised to clients in MatchmakingSucceeded (the arena UDP endpoint
# the client dials). For real-client testing over the arena WG, set this to the
# box's WG/public address; leave 127.0.0.1 for local-only.
ARENA_ADVERTISE_HOST=127.0.0.1
ARENA_UDP_PORT=7777

# Cap on simultaneous live matches. 16 is fine on this box — a match is tiny, and
# the registry now reclaims abandoned/leaked slots (sweep_expired), so a couple of
# failed connects no longer jam the queue. (Was 2, which jammed testing.)
ARENA_MAX_MATCHES=16

# --- Per-match key submission (makes OUR-server arena matches decryptable) ---
# The arena-server derives each peer's ChaCha20 key+nonce in the op-0x38
# handshake and fire-and-forget POSTs it to the capture platform's
# /api/arena/submit-key, tagged gamelift_ip=10.99.0.1 port=7777, so pcap-ingest
# (which now always targets 10.99.0.1:7777) + arena-decrypt can pair the
# captured frames with the key. Reaches newblades-web by service name over the
# shared edge_net (plain HTTP, reuses the web handler's auth + insert).
#
# ARENA_SUBMIT_TOKEN is REQUIRED for submission to actually happen: it's a
# frida_submit_tokens bearer token mapping to a designated users.id (mint one in
# the web app — e.g. the /dashboard/rig token for an internal user — or INSERT a
# row). Leave empty to keep submission off. Set ARENA_SUBMIT_KEYS=0 to disable
# regardless of token.
ARENA_SUBMIT_KEYS=1
ARENA_SUBMIT_TOKEN=
# Optional overrides (defaults shown):
# ARENA_SUBMIT_URL=http://newblades-web:3000/api/arena/submit-key
# ARENA_SUBMIT_GAMELIFT_IP=10.99.0.1
# ARENA_SUBMIT_GAMELIFT_PORT=7777

# info shows the high-value diagnostics (allocate/resolve, ENet connect/disconnect,
# liveness heartbeat, FSM transitions, match-end frame bytes, sweep reclaims, SNAT
# warnings). For per-input/per-damage combat detail add: server::arena::combat=debug
RUST_LOG=info
